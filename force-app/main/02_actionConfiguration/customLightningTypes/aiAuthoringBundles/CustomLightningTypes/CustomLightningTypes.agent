# CustomLightningTypes - Using Custom Lightning Types for Rich Input and Output UI
# This agent demonstrates how to use CLTs to override default agent UI with custom LWC components

config:
   developer_name: "CustomLightningTypes"
   agent_label: "CustomLightningTypes"
   agent_type: "AgentforceEmployeeAgent"
   description: "Submits support cases using Custom Lightning Types for rich input and output UI"

variables:
   case_submitted: mutable boolean = False
   case_number: mutable string = ""

system:
   messages:
      welcome: "Hi! I can help you submit a support case. Let me know when you are ready."
      error: "Something went wrong while processing your case. Please try again."
   instructions: "You are a support assistant that helps users submit structured support cases using a custom form."

start_agent topic_selector:
   description: "Welcome users and route to case submission"

   reasoning:
      instructions:|
         Select the tool that best matches the user's message and conversation history. If it's unclear, make your best guess.
      actions:
         begin_case_submission: @utils.transition to @topic.case_submission
            description: "Start helping with case submission"

topic case_submission:
   description: "Collects case details via a CLT form and displays the created case"

   reasoning:
      instructions: ->
         if not @variables.case_submitted:
            | The user wants to submit a support case.
              Call {!@actions.submit_case} action's user_input tool to present the case form to the user.
              The form collects all required information (subject, priority, and description). Do NOT ask the user for any additional fields or confirmation.
              Once the user submits the form, immediately invoke the {!@actions.submit_case} action with the provided data. Do not ask follow-up questions before submitting.
              After submission, display the case result to the user and share the case number.
         else:
            | The case has already been submitted.
              - Case Number: {!@variables.case_number}
              Display the case result to the user and ask if they need anything else.

      actions:
         submit_case: @actions.submit_case
            with case_data = ...

   actions:
      submit_case:
         description: "Submits a support case"
         inputs:
            case_data: object
               description: "Case details including subject, priority, and description"
               label: "case_data"
               is_required: True
               is_user_input: True
               complex_data_type_name: "c__caseInput"
         outputs:
            case_number: string
               description: "The case number assigned to the new case"
               label: "case_number"
               filter_from_agent: False
               is_displayable: False
            case_result: object
               description: "The created case details for display"
               label: "case_result"
               complex_data_type_name: "c__caseResult"
               filter_from_agent: False
               is_displayable: True
         target: "apex://CaseSubmissionService"
         label: "Submit Case"
         require_user_confirmation: False
         include_in_progress_indicator: True
         progress_indicator_message: "Submitting your case..."
         source: "Submit_Case"
